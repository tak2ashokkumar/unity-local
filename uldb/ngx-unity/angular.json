{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "cli": {
    "analytics": "af945aa4-c424-4b70-bd18-3e6d65431b58"
  },
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "ngx-unity": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        },
        "@schematics/angular:application": {
          "strict": false
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "",
      "architect": {
        "build": {
          "builder": "@angular-builders/custom-webpack:browser",
          "options": {
            "customWebpackConfig": {
              "path": "./extra-webpack-dev.config.js",
              "mergeStrategies": {
                "externals": "replace"
              }
            },
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": "src/polyfills.ts",
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "src/favicon.ico",
              "src/assets"
            ],
            "styles": [
              "src/styles/glyphter-font/scss/Unity.scss",
              "node_modules/xterm/css/xterm.css",
              "src/styles/scss/style.scss",
              "src/styles.scss",
              "node_modules/drawflow/dist/drawflow.min.css",
              "node_modules/codemirror/lib/codemirror.css",
              "node_modules/codemirror/theme/material.css",
              "node_modules/codemirror/theme/dracula.css",
              "node_modules/codemirror/theme/monokai.css",
              "node_modules/codemirror/theme/blackboard.css",
              "node_modules/codemirror/theme/midnight.css",
              "node_modules/codemirror/addon/lint/lint.css",
              "node_modules/codemirror/addon/hint/show-hint.css",
              "node_modules/@ng-select/ng-select/themes/default.theme.css"
            ],
            "scripts": [
              "node_modules/vis-network/standalone/umd/vis-network.min.js",
              "src/assets/js/prototype-override.js",
              "node_modules/leader-line/leader-line.min.js",
              "node_modules/skulpt/dist/skulpt.min.js",
              "node_modules/skulpt/dist/skulpt-stdlib.js"
            ]
          },
          "configurations": {
            "production": {
              "customWebpackConfig": {
                "path": "./extra-webpack-prod.config.js",
                "mergeStrategies": {
                  "externals": "replace"
                }
              },
              "outputPath": "../static/dist",
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "10mb",
                  "maximumError": "15mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "10kb",
                  "maximumError": "40kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all",
              "optimization": {
                "scripts": true,
                "fonts": {
                  "inline": true
                },
                "styles": {
                  "minify": true,
                  "inlineCritical": false
                }
              },
              "sourceMap": false,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "vendorChunk": true,
              "buildOptimizer": true,
              "stylePreprocessorOptions": {
                "includePaths": [
                  "src/styles/scss",
                  "./node_modules",
                  "src/styles/glyphter-font/scss/prod"
                ]
              }
            },
            "development": {
              "outputPath": "dist",
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true,
              "stylePreprocessorOptions": {
                "includePaths": [
                  "src/styles/scss",
                  "./node_modules",
                  "src/styles/glyphter-font/scss/dev"
                ]
              }
            },
            "testProd": {
              "customWebpackConfig": {
                "path": "./extra-webpack-dev.config.js",
                "mergeStrategies": {
                  "externals": "replace"
                }
              },
              "outputPath": "dist",
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "3mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "10kb",
                  "maximumError": "40kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all",
              "optimization": {
                "scripts": true,
                "fonts": {
                  "inline": true
                },
                "styles": {
                  "minify": true,
                  "inlineCritical": false
                }
              },
              "sourceMap": false,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "vendorChunk": true,
              "buildOptimizer": true,
              "stylePreprocessorOptions": {
                "includePaths": [
                  "src/styles/scss",
                  "./node_modules",
                  "src/styles/glyphter-font/scss/dev"
                ]
              }
            }
          },
          "defaultConfiguration": "development"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "browserTarget": "ngx-unity:build:production"
            },
            "development": {
              "browserTarget": "ngx-unity:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "ngx-unity:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "src/test.ts",
            "polyfills": "src/polyfills.ts",
            "tsConfig": "tsconfig.spec.json",
            "karmaConfig": "karma.conf.js",
            "inlineStyleLanguage": "scss",
            "assets": [
              "src/favicon.ico",
              "src/assets"
            ],
            "styles": [
              "src/styles.scss"
            ],
            "scripts": []
          }
        }
      }
    }
  },
  "defaultProject": "ngx-unity"
}